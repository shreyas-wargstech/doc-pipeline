# Postgres
DATABASE_URL=postgresql+asyncpg://pipeline:pipeline@localhost:5432/doc_pipeline

# S3 (MinIO for local dev — leave S3_ENDPOINT_URL blank for real AWS)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=us-east-1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=document_pages

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pipeline-dev

# OCR
OCR_CONFIDENCE_THRESHOLD=70

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# SQS
SQS_OCR_QUEUE_URL=  
AWS_REGION=ap-south-1
SQS_ENDPOINT_URL=  